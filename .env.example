# Database URL
DATABASE_URL="postgres://<user>:<password>@<url>:<port>/<db_name>"

# --- Database connection pool settings for traditional servers ---
# These values are suitable for development and will be overridden by the logic
# in `lib/database/connection.ts` in a serverless environment.
# DB_POOL_SIZE=20
# DB_IDLE_TIMEOUT=300
# DB_MAX_LIFETIME=14400
# DB_CONNECT_TIMEOUT=30
# Must be overwritten by your trusted reverse proxy.
RATE_LIMIT_IP_HEADER=x-forwarded-for

# Application settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional OAuth credentials. Uncomment both values for each provider you use.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# Better Auth Secret
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"

# API keys
RESEND_API_KEY="required"
RESEND_EMAIL_FROM="noreply@your-verified-domain.com"

# Cloudflare R2 Storage
R2_ENDPOINT="https://YOUR-ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"
R2_PUBLIC_URL="https://your-custom-domain.com"
# Used by the scheduled upload-intent cleanup endpoint.
UPLOAD_CLEANUP_SECRET="replace-with-at-least-32-random-characters"
# Optional byte quotas. Defaults: 1 GiB per rolling 24 hours, 5 GiB total.
# UPLOAD_DAILY_QUOTA_BYTES=1073741824
# UPLOAD_TOTAL_QUOTA_BYTES=5368709120
# Set both values only for a bounded v1-to-v2 rolling deployment.
# Remove both variables after the migration window.
# UPLOAD_LEGACY_COMPLETION_SINCE="2026-07-25T00:00:00.000Z"
# UPLOAD_LEGACY_COMPLETION_UNTIL="2026-07-26T00:00:00.000Z"

# Payments
# test_mode / live_mode
CREEM_ENVIRONMENT=test_mode
CREEM_API_KEY=creem_test_api_key_here
CREEM_WEBHOOK_SECRET=whsec_test_secret_here
