{
  "name": "ullrai-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:slow": "next dev",
    "build": "AI_SDK_LOG_WARNINGS=false next build --webpack && node scripts/sync-lingo-cache.mjs",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "drizzle-kit generate --config=src/database/config.ts",
    "db:generate:prod": "drizzle-kit generate --config=src/database/config.prod.ts",
    "db:migrate": "drizzle-kit migrate --config=src/database/config.ts",
    "db:migrate:dev": "drizzle-kit migrate --config=src/database/config.ts",
    "db:migrate:prod": "drizzle-kit migrate --config=src/database/config.prod.ts",
    "db:push": "drizzle-kit push --config=src/database/config.ts",
    "prettier:check": "prettier --check --ignore-path .gitignore .",
    "prettier:format": "prettier --write --ignore-path .gitignore .",
    "analyze": "ANALYZE=true next build",
    "analyze:dev": "ANALYZE=true next dev",
    "set:admin": "tsx --env-file=.env scripts/set-admin.ts",
    "set:admin:prod": "tsx scripts/set-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/lib-storage": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@hookform/resolvers": "^5.2.2",
    "@keystatic/core": "^0.5.48",
    "@keystatic/next": "^5.0.4",
    "@lingo.dev/compiler": "^0.3.12",
    "@markdoc/markdoc": "^0.5.5",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.13.10",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "creem": "^1.3.6",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.35.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "mailchecker": "^6.0.19",
    "next": "^16.1.6",
    "next-safe-action": "^8.1.5",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nuqs": "^2.8.9",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "use-debounce": "^10.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@jest/globals": "^30.2.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@inkjs/ui>ink": "^4.0.0",
        "@lingo.dev/_react>next": "^16.0.0",
        "@openrouter/ai-sdk-provider>ai": "^6.0.0",
        "@openrouter/ai-sdk-provider>zod": "^4.0.0",
        "eslint-plugin-import>eslint": "^10.0.0",
        "eslint-plugin-jsx-a11y>eslint": "^10.0.0",
        "eslint-plugin-react-hooks>eslint": "^10.0.0",
        "eslint-plugin-react>eslint": "^10.0.0",
        "react-reconciler>react": "^19.0.0"
      }
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
